extends layout

block content
  .home-hero
    .home-hero__featured
      img.home-hero__featured-image(src='/images/donutShop.jpg' alt='Placeholder hero image')
      .home-hero__overlay
        h1.home-hero__title Fresh donuts, made daily
        p.home-hero__text Stop in for handcrafted favorites and a warm cup of coffee.

    .home-hero__cards
      a.home-hero__card(href='/menu')
        img.home-hero__image(src='/images/donut.jpg' alt='Placeholder menu image')
        .home-hero__card-content
          h2 Menu
          p See our signature donuts and drinks.

      a.home-hero__card(href='/about')
        img.home-hero__image(src='/images/donutPerson2.png' alt='Placeholder story image')
        .home-hero__card-content
          h2 Our Story
          p Learn about our family-owned bakery.

      a.home-hero__card(href='/comments')
        img.home-hero__image(src='/images/review.png' alt='Placeholder comments image')
        .home-hero__card-content
          h2 Comments
          p Read what guests are saying.
